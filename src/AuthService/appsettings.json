{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=auth;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Key": "scada-jwt-dev-secret-key-must-be-at-least-32-bytes-long!",
    "Issuer": "scada-auth-service",
    "Audience": "scada-platform",
    "AccessTokenExpiryMinutes": "15",
    "SensorTokenExpiryDays": "365",
    "RefreshTokenExpiryDays": "7"
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=analytics;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "scada-jwt-dev-secret-key-must-be-at-least-32-bytes-long!",
    "Issuer": "scada-auth-service",
    "Audience": "scada-platform"
  },
  "Services": {
    "Ingestion":  "http://ingestion-service:8080",
    "Consensus":  "http://consensus-service:8080",
    "SensorMgmt": "http://sensormgmt-service:8080"
  },
  "Cache": {
    "TtlSeconds": "30"
  }
}

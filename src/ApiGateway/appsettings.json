{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AuthService": {
    "BaseUrl": "http://auth-service:8080"
  },
  "RateLimit": {
    "PermitLimit": "10",
    "WindowSeconds": "1"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "ingest-route": {
        "ClusterId": "ingestion-cluster",
        "Match": { "Path": "/api/ingest/{**catch-all}" }
      },
      "sensors-route": {
        "ClusterId": "sensormgmt-cluster",
        "Match": { "Path": "/api/sensors/{**catch-all}" }
      },
      "reports-route": {
        "ClusterId": "analytics-cluster",
        "Match": { "Path": "/api/reports/{**catch-all}" }
      },
      "ws-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/ws/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "d1": { "Address": "http://auth-service:8080" } }
      },
      "ingestion-cluster": {
        "Destinations": { "d1": { "Address": "http://ingestion-service:8080" } }
      },
      "sensormgmt-cluster": {
        "Destinations": { "d1": { "Address": "http://sensormgmt-service:8080" } }
      },
      "analytics-cluster": {
        "Destinations": { "d1": { "Address": "http://analytics-service:8080" } }
      },
      "notification-cluster": {
        "Destinations": { "d1": { "Address": "http://notification-service:8080" } }
      }
    }
  }
}
